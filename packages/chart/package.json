{
  "name": "@barefootjs/chart",
  "version": "0.0.1",
  "description": "SVG chart components for BarefootJS with signal-based reactivity",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --format esm",
    "build:types": "tsgo --emitDeclarationOnly --outDir ./dist",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "chart",
    "area-chart",
    "bar-chart",
    "svg",
    "signals",
    "reactive",
    "barefoot"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/barefootjs/barefootjs",
    "directory": "packages/chart"
  },
  "peerDependencies": {
    "@barefootjs/client": ">=0.0.1"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.8",
    "typescript": "^5.0.0"
  }
}
