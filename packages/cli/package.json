{
  "name": "@barefootjs/cli",
  "version": "0.26.0",
  "description": "CLI for agent-driven UI component discovery and scaffolding",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bf": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "author": "kobaken <kentafly88@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/piconic-ai/barefootjs",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "node ./scripts/embed-runtimes.mjs && node ./scripts/build.mjs",
    "embed-runtimes": "node ./scripts/embed-runtimes.mjs",
    "clean": "rm -rf dist src/lib/adapters/runtimes.generated.ts",
    "test": "node ./scripts/embed-runtimes.mjs && bun test"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0",
