{
  "name": "@barefootjs/router",
  "version": "0.16.0",
  "description": "Backend-agnostic partial-navigation client router for BarefootJS — swaps only the page region and re-hydrates the islands inside it",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugins": "./src/plugins.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./plugins": {
        "types": "./dist/plugins.d.ts",
        "import": "./dist/plugins.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:js && bun run build:standalone && bun run build:types",
    "build:js": "bun build ./src/index.ts ./src/plugins.ts --outdir ./dist --format esm --external @barefootjs/shared --external @barefootjs/client --external @barefootjs/jsx",
    "build:standalone": "bun build ./src/index.ts --outfile ./dist/standalone.js --format esm --external @barefootjs/client",
    "build:types": "tsgo --emitDeclarationOnly --outDir ./dist",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepack": "node ../../scripts/swap-publish-config.mjs pack",
    "postpack": "node ../../scripts/swap-publish-config.mjs unpack"
  },
  "keywords": [
    "barefoot",
    "router",
    "spa",
    "partial-navigation",
    "islands",
    "region"
  ],
  "author": "kobaken <kentafly88@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/piconic-ai/barefootjs",
    "directory": "packages/router"
  },
  "dependencies": {
    "@barefootjs/shared": "workspace:*"
  },
  "peerDependencies": {
    "@barefootjs/client": ">=0.14.0",
    "@barefootjs/jsx": ">=0.16.0"
  },
  "peerDependenciesMeta": {
    "@barefootjs/client": {
      "optional": true
    },
    "@barefootjs/jsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@barefootjs/client": "^0.16.0",
    "@barefootjs/jsx": "workspace:*",
    "@happy-dom/global-registrator": "^20.0.11",
    "typescript": "^5.0.0"
  }
}
