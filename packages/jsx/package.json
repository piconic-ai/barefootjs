{
  "name": "@barefootjs/jsx",
  "version": "0.15.1",
  "description": "JSX compiler for BarefootJS - transforms JSX to server HTML + client JS",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./scanner": {
      "types": "./src/scanner/js-scanner.ts",
      "import": "./src/scanner/js-scanner.ts"
    },
    "./import-map": {
      "types": "./src/import-map.ts",
      "import": "./src/import-map.ts"
    },
    "./jsx-runtime": {
      "types": "./src/jsx-runtime/index.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx-dev-runtime/index.ts"
    }
  },
  "//publishConfig": "At pack time, swap-publish-config.mjs merges these overrides into the top-level so the published tarball resolves entry points to dist/ instead of src/. Exceptions: ./jsx-runtime and ./jsx-dev-runtime are type-only shims with no runtime/build output, so they stay at their src/*.ts (no dist/ sibling exists). Workspace exports stay at src/ so bun resolves source directly during dev.",
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./scanner": {
        "types": "./dist/scanner/js-scanner.d.ts",
        "import": "./dist/scanner/js-scanner.js"
      },
      "./import-map": {
        "types": "./dist/import-map.d.ts",
        "import": "./dist/import-map.js"
      },
      "./jsx-runtime": {
        "types": "./src/jsx-runtime/index.ts"
      },
      "./jsx-dev-runtime": {
        "types": "./src/jsx-dev-runtime/index.ts"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts ./src/scanner/js-scanner.ts ./src/import-map.ts --root ./src --outdir ./dist --format esm --external typescript --external @barefootjs/shared --external @barefootjs/client",
    "build:types": "tsgo --emitDeclarationOnly --outDir ./dist",
    "test": "bun test && bun run typecheck:tests",
    "typecheck:tests": "tsgo --noEmit -p __tests__/tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "node ../../scripts/swap-publish-config.mjs pack",
    "postpack": "node ../../scripts/swap-publish-config.mjs unpack"
  },
  "keywords": [
    "jsx",
    "compiler",
    "barefoot",
    "ssr"
  ],
  "author": "kobaken <kentafly88@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/piconic-ai/barefootjs",
    "directory": "packages/jsx"
  },
  "dependencies": {
    "@barefootjs/shared": "workspace:*"
  },
  "peerDependencies": {
    "@barefootjs/client": ">=0.2.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.11"
  }
}
