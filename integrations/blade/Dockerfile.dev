# syntax=docker/dockerfile:1
#
# Development image for the Blade integration. index.php and the host-built
# dist/ + lib/ + vendor/ are bind-mounted in. There is no reloader to
# restart here (unlike Flask's Werkzeug reloader) -- PHP's built-in server
# re-executes index.php fresh on every request, and BladeBackend's
# CompilerEngine recompiles a view whenever its source mtime is newer than
# its compiled cache file (see index.php's `$backend` construction), so edits
# to index.php or the compiled templates are picked up on the very next
# request with no restart needed.

FROM php:8.4-cli

WORKDIR /workspace/integrations/blade

EXPOSE 3015

ENV BASE_PATH=/integrations/blade
ENV PORT=3015

CMD ["sh", "-c", "PHP_CLI_SERVER_WORKERS=8 php -S 0.0.0.0:${PORT} index.php"]
