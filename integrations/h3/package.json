{
  "name": "barefootjs-h3-example",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "build": "bun run ../../packages/cli/src/index.ts build && bun run scripts/build-client.ts && bun run scripts/assemble-public.ts",
    "build:watch": "bun run ../../packages/cli/src/index.ts build --watch",
    "dev": "bun run build && wrangler dev",
    "deploy": "bun run build && wrangler deploy",
    "start": "bun run server.tsx",
    "test:e2e": "bunx playwright test"
  },
  "dependencies": {
    "@barefootjs/client": "workspace:*",
    "@barefootjs/hono": "workspace:*",
    "@barefootjs/jsx": "workspace:*",
    "@barefootjs/router": "workspace:*",
    "@barefootjs/shared": "workspace:*",
    "h3": "^1.13.0",
    "hono": "^4"
  },
  "devDependencies": {
    "bun-types": "^1.1.0",
    "wrangler": "^4"
  }
}
